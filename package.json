{
	"name": "@erhai_lake/mock-service",
	"version": "0.0.4-beta.3",
	"description": "mock-service is a JavaScript library for generating simulation data and supporting variables and templates. It provides a wealth of generators, as well as the corresponding processor, can help developers quickly generate simulation data that meet the requirements.",
	"keywords": [
		"mock",
		"service",
		"faker",
		"data-generator"
	],
	"license": "MIT",
	"homepage": "https://github.com/Erhai-lake/mock-service#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/Erhai-lake/mock-service.git"
	},
	"bugs": {
		"url": "https://github.com/Erhai-lake/mock-service/issues"
	},
	"publishConfig": {
		"provenance": true
	},
	"type": "module",
	"main": "./dist/index.cjs.js",
	"module": "./dist/index.esm.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"package.json"
	],
	"devDependencies": {
		"@types/crypto-js": "^4.2.2",
		"@types/luxon": "^3.7.1",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"crypto-js": "^4.2.0",
		"luxon": "^3.7.2",
		"nanoid": "^5.1.6",
		"uuid": "^13.0.0"
	}
}
